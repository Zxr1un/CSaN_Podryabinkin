<Window x:Class="_3laba_P2P.MainWindow"
            xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="clr-namespace:_3laba_P2P"
    mc:Ignorable="d"
    Title="P2P chat" Height="800" Width="1200" Closing="Window_Closing">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="80"/>
            <RowDefinition Height="10*"/>
            <RowDefinition Height="5*"/>
            <RowDefinition Height="50"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="0.8*"/>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="1*"/>
        </Grid.ColumnDefinitions>
        <TextBox x:Name="ChatField" TextWrapping="Wrap" Text="" Grid.Row="1" Grid.Column="1" Margin="10,10,10,10" IsReadOnly="True"/>
        <Label x:Name="NodesLabel" Content="Узлы" Margin="5,5,5,5"/>
        <Label Grid.Column="1" Content="Чат" HorizontalAlignment="Center" VerticalAlignment="Center"/>
        <Label Grid.Column="2" Content="Журнал событий" HorizontalAlignment="Center" VerticalAlignment="Center"/>
        <ListBox x:Name ="NodesList"  Grid.Row="1" Margin="5,5,5,5" Grid.RowSpan="1" ItemsSource="{Binding Source={x:Static local:NetworkOperations.NodesUI}}" SelectionChanged="NodesList_SelectionChanged">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding Name}" FontWeight="Bold"/>
                        <TextBlock Text="{Binding IP}" Margin="10,0,0,0"/>
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
            
        </ListBox>
        
        <Grid Grid.Column="2" Grid.Row="1" Grid.RowSpan="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="1*"/>
            </Grid.RowDefinitions>
            <Label Content="история отладки с текущего узла" Margin="5,5,5,5"/>
            <TextBox x:Name="StoryCurrent" Margin="5,10,5,5" Grid.Row="1" TextWrapping="Wrap" Text="" FontSize="8" IsReadOnly="True"/>

        </Grid>
        <Button x:Name ="RefrashNodesButton" Content="Обновить узлы принудительно" HorizontalAlignment="Left" Margin="5,5,5,5" Grid.Row="3" Click="RefrashNodesButton_Click"/>
        <Button x:Name ="SendMessageButton" Grid.Column="1" Content="отправить сообщение" Margin="5,5,5,5" Grid.Row="3" Click="SendMessageButton_Click"/>

        <Button x:Name="ChangeNameIP" Grid.Column="2" Content="Сменить имя и IP" Margin="5,5,5,5" Grid.Row="3" Click="ChangeNameIP_Click"/>
        <Grid Grid.Column="1" Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="1*"/>
            </Grid.RowDefinitions>

            <TextBox x:Name="ChatInput" Grid.Column="1" Margin="10,10,10,10" Grid.Row="2" TextWrapping="Wrap" Text=""/>
            <Label Content="Ваш ввод:" HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Grid>
        <CheckBox x:Name="ChB" Grid.Column="1" Content="Debug" HorizontalAlignment="Right" Margin="0,20,20,0" VerticalAlignment="Top" Checked="CheckBox_Checked" Unchecked="CheckBox_Unchecked" IsChecked="True"/>
        <Button x:Name ="GotNodeHystory" Content="Запросить историю узла" Margin="20,20,20,0" Grid.Row="2" VerticalAlignment="Top" Click="GotNodeHystory_Click"/>
        <Button x:Name="ResetChat" Content="Сбросить свой чат" Margin="20,50,20,0" Grid.Row="2" VerticalAlignment="Top" Click="ResetChat_Click"/>


    </Grid>
</Window>
