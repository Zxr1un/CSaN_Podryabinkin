<Window x:Class="_3laba_P2P.SetNameIP"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:_3laba_P2P"
        mc:Ignorable="d"
        Title="SetNameIP" Height="300" Width="400" Closing="Window_Closing">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="50" />
            <RowDefinition Height="50"/>
            <RowDefinition Height="50"/>
            <RowDefinition Height="50" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="150" />
        </Grid.ColumnDefinitions>

        <!-- Метка для IP -->
        <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Text="Выберите IP:"/>
        <ComboBox x:Name="IpComboBox" Grid.Row="0" Grid.Column="1" Margin="5,5,5,5" SelectionChanged="InputChanged"/>

        <!-- Метка для имени -->
        <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Text="Имя пользователя:"/>
        <TextBox x:Name="NameTextBox" Grid.Row="1" Grid.Column="1" Margin="5,5,5,5" TextChanged="InputChanged"/>

        <!-- Кнопка подтверждения -->
        <Button x:Name="OkButton" Grid.Row="2" Grid.ColumnSpan="2" Content="Подтвердить" Width="120" Height="30" Margin="0,20,0,0"
            HorizontalAlignment="Center" IsEnabled="False" Click="OkButton_Click"/>
        <Label Content="Широковещательный адресс" Margin="5,5,5,5" Grid.Row="3"/>
        <Label x:Name="BroadcastLabel" Grid.Column="1" Content="Label" Margin="5,5,5,5" Grid.Row="3"/>
        <CheckBox Content="Debug" HorizontalAlignment="Left" Margin="5,6,0,0" Grid.Row="4" VerticalAlignment="Top" IsChecked="True" Checked="CheckBox_Checked" Unchecked="CheckBox_Unchecked"/>
    </Grid>
</Window>
